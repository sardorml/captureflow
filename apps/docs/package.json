{
  "name": "@captureflow/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CaptureFlow documentation site (VitePress).",
  "scripts": {
    "dev": "vitepress dev --port 3033 --strictPort",
    "build": "vitepress build",
