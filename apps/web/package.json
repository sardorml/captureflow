{
  "name": "@captureflow/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3032",
    "build": "next build",
    "start": "next start",
    "lint": "echo \"(web) lint: TODO\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:seed:local": "wrangler d1 execute captureflow --local --file=./db/schema.snapshot.sql",
    "db:apply": "wrangler d1 migrations apply captureflow",
    "db:apply:remote": "wrangler d1 migrations apply captureflow --remote"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@base-ui/react": "^1.3.0",
    "@better-auth/drizzle-adapter": "1.6.10",
    "@captureflow/quota": "workspace:*",
    "@captureflow/shared": "workspace:*",
    "@captureflow/ui": "workspace:*",
    "@opennextjs/cloudflare": "^1.19.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "antd": "^6.4.5",
    "better-auth": "1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "emoji-picker-react": "^4.19.1",
    "konva": "^10.3.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.0",
    "posthog-js": "^1.386.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-konva": "^19.2.4",
    "react-medium-image-zoom": "^5.4.5",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "^4",
    "typescript": "catalog:",
    "vitest": "^4.1.9",
    "wrangler": "^4.40.0"
  }
}
