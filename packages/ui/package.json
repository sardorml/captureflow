{
  "name": "@captureflow/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared shadcn/ui primitives — Button, Card, Avatar, Dialog, etc. — and the cn() helper. Consumed across CaptureFlow's web surfaces (dashboard, recording page, screenshot page) so the dashboard, recording page, and screenshot page render with the same visual vocabulary.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cn": "./src/lib/cn.ts",
    "./avatar": "./src/ui/avatar.tsx",
    "./badge": "./src/ui/badge.tsx",
    "./button": "./src/ui/button.tsx",
    "./card": "./src/ui/card.tsx",
    "./dialog": "./src/ui/dialog.tsx",
    "./dropdown-menu": "./src/ui/dropdown-menu.tsx",
    "./input": "./src/ui/input.tsx",
    "./label": "./src/ui/label.tsx",
    "./radio-group": "./src/ui/radio-group.tsx",
    "./separator": "./src/ui/separator.tsx",
    "./textarea": "./src/ui/textarea.tsx",
    "./smooth-button": "./src/ui/smooth-button.tsx",
    "./smooth-dialog": "./src/ui/smooth-dialog.tsx",
    "./smooth-dropdown-menu": "./src/ui/smooth-dropdown-menu.tsx",
    "./grid-loader": "./src/ui/grid-loader.tsx",
    "./avatar-group": "./src/ui/avatar-group.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "lucide-react": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5"
  }
}
